# =============================================================================
# nextjs-app/.dockerignore — DEVELOPMENT
# =============================================================================

# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules
.pnpm-store

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/

# ── Environment files ─────────────────────────────────────────────────────────
# Runtime env vars are injected via docker-compose env_file.
.env
.env.*
.env.local
.env.local.*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Docker ────────────────────────────────────────────────────────────────────
Dockerfile
.dockerignore

# ── Misc ──────────────────────────────────────────────────────────────────────
README.md
AGENTS.md
CLAUDE.md
docs/
*.tsbuildinfo
